      "html": "\n<div class=\"w-full bg-[#120F17] py-24 flex flex-col items-center justify-center font-sans antialiased\" data-kid=\"0\">\n    \n    <div class=\"text-center mb-16 px-6\" data-kid=\"1\">\n        <h2 class=\"text-4xl md:text-5xl font-extrabold text-white tracking-tight mb-4\" data-kid=\"2\">\n            Common Inquiries\n        </h2>\n        <p class=\"text-gray-400 text-lg max-w-xl mx-auto\" data-kid=\"3\">\n            Everything you need to know about our investment philosophy and process.\n        </p>\n    </div>\n\n    \n    <div class=\"relative w-full max-w-[640px] px-4\" data-kid=\"4\">\n        \n        \n        <div id=\"top-gradient\" class=\"absolute top-0 left-0 right-0 h-12 bg-gradient-to-b from-[#120F17] to-transparent z-20 pointer-events-none opacity-0 transition-opacity duration-300\" data-kid=\"5\"></div>\n\n        \n        <div id=\"list-container\" class=\"relative max-h-[480px] overflow-y-auto px-2 py-6 space-y-4 scroll-smooth\n                    [&::-webkit-scrollbar]:w-[4px] \n                    [&::-webkit-scrollbar-track]:bg-[#120F17] \n                    [&::-webkit-scrollbar-thumb]:bg-[#333] \n                    [&::-webkit-scrollbar-thumb]:rounded-full\" data-kid=\"6\">\n            \n            \n            <div class=\"faq-item opacity-0 scale-90 translate-y-4 transition-all duration-500 ease-out\" data-index=\"0\" data-kid=\"7\">\n                <div class=\"bg-[#111] rounded-xl border border-white/5 overflow-hidden transition-colors duration-300 hover:bg-[#1a1a1a]\" data-kid=\"8\">\n                    <button class=\"faq-trigger w-full flex justify-between items-center p-6 text-left text-white font-semibold focus:outline-none group\" data-kid=\"9\">\n                        <span class=\"text-lg\" data-kid=\"10\">What stages do you invest in?</span>\n                        <i data-lucide=\"chevron-down\" class=\"lucide-icon w-5 h-5 text-gray-500 group-hover:text-white transition-transform duration-300\" data-kid=\"11\"></i>\n                    </button>\n                    <div class=\"faq-answer max-h-0 overflow-hidden transition-all duration-300 ease-in-out\" data-kid=\"12\">\n                        <div class=\"px-6 pb-6 text-gray-400 leading-relaxed\" data-kid=\"13\">\n                            We invest from Pre-Seed through Series B and beyond, depending on the opportunity. We're looking for visionary founders at various stages of their journey.\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"faq-item opacity-0 scale-90 translate-y-4 transition-all duration-500 ease-out\" data-index=\"1\" data-kid=\"14\">\n                <div class=\"bg-[#111] rounded-xl border border-white/5 overflow-hidden transition-colors duration-300 hover:bg-[#1a1a1a]\" data-kid=\"15\">\n                    <button class=\"faq-trigger w-full flex justify-between items-center p-6 text-left text-white font-semibold focus:outline-none group\" data-kid=\"16\">\n                        <span class=\"text-lg\" data-kid=\"17\">Do you invest outside India?</span>\n                        <i data-lucide=\"chevron-down\" class=\"lucide-icon w-5 h-5 text-gray-500 group-hover:text-white transition-transform duration-300\" data-kid=\"18\"></i>\n                    </button>\n                    <div class=\"faq-answer max-h-0 overflow-hidden transition-all duration-300 ease-in-out\" data-kid=\"19\">\n                        <div class=\"px-6 pb-6 text-gray-400 leading-relaxed\" data-kid=\"20\">\n                            Yes, we invest globally with a focus on emerging markets and high-growth regions. Our network spans multiple continents to support international expansion.\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"faq-item opacity-0 scale-90 translate-y-4 transition-all duration-500 ease-out\" data-index=\"2\" data-kid=\"21\">\n                <div class=\"bg-[#111] rounded-xl border border-white/5 overflow-hidden transition-colors duration-300 hover:bg-[#1a1a1a]\" data-kid=\"22\">\n                    <button class=\"faq-trigger w-full flex justify-between items-center p-6 text-left text-white font-semibold focus:outline-none group\" data-kid=\"23\">\n                        <span class=\"text-lg\" data-kid=\"24\">How long does the process take?</span>\n                        <i data-lucide=\"chevron-down\" class=\"lucide-icon w-5 h-5 text-gray-500 group-hover:text-white transition-transform duration-300\" data-kid=\"25\"></i>\n                    </button>\n                    <div class=\"faq-answer max-h-0 overflow-hidden transition-all duration-300 ease-in-out\" data-kid=\"26\">\n                        <div class=\"px-6 pb-6 text-gray-400 leading-relaxed\" data-kid=\"27\">\n                            From application to term sheet typically takes 3–6 weeks depending on due diligence. We pride ourselves on being founder-friendly and moving at venture speed.\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"faq-item opacity-0 scale-90 translate-y-4 transition-all duration-500 ease-out\" data-index=\"3\" data-kid=\"28\">\n                <div class=\"bg-[#111] rounded-xl border border-white/5 overflow-hidden transition-colors duration-300 hover:bg-[#1a1a1a]\" data-kid=\"29\">\n                    <button class=\"faq-trigger w-full flex justify-between items-center p-6 text-left text-white font-semibold focus:outline-none group\" data-kid=\"30\">\n                        <span class=\"text-lg\" data-kid=\"31\">What equity stake do you take?</span>\n                        <i data-lucide=\"chevron-down\" class=\"lucide-icon w-5 h-5 text-gray-500 group-hover:text-white transition-transform duration-300\" data-kid=\"32\"></i>\n                    </button>\n                    <div class=\"faq-answer max-h-0 overflow-hidden transition-all duration-300 ease-in-out\" data-kid=\"33\">\n                        <div class=\"px-6 pb-6 text-gray-400 leading-relaxed\" data-kid=\"34\">\n                            We typically take 5–15% equity, negotiated based on stage and valuation. Our goal is to ensure founders remain incentivized while providing us with a meaningful stake.\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"faq-item opacity-0 scale-90 translate-y-4 transition-all duration-500 ease-out\" data-index=\"4\" data-kid=\"35\">\n                <div class=\"bg-[#111] rounded-xl border border-white/5 overflow-hidden transition-colors duration-300 hover:bg-[#1a1a1a]\" data-kid=\"36\">\n                    <button class=\"faq-trigger w-full flex justify-between items-center p-6 text-left text-white font-semibold focus:outline-none group\" data-kid=\"37\">\n                        <span class=\"text-lg\" data-kid=\"38\">Do you lead rounds?</span>\n                        <i data-lucide=\"chevron-down\" class=\"lucide-icon w-5 h-5 text-gray-500 group-hover:text-white transition-transform duration-300\" data-kid=\"39\"></i>\n                    </button>\n                    <div class=\"faq-answer max-h-0 overflow-hidden transition-all duration-300 ease-in-out\" data-kid=\"40\">\n                        <div class=\"px-6 pb-6 text-gray-400 leading-relaxed\" data-kid=\"41\">\n                            We can lead or co-invest depending on the deal structure and existing cap table. We often work alongside other top-tier VC firms and angel investors.\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"faq-item opacity-0 scale-90 translate-y-4 transition-all duration-500 ease-out\" data-index=\"5\" data-kid=\"42\">\n                <div class=\"bg-[#111] rounded-xl border border-white/5 overflow-hidden transition-colors duration-300 hover:bg-[#1a1a1a]\" data-kid=\"43\">\n                    <button class=\"faq-trigger w-full flex justify-between items-center p-6 text-left text-white font-semibold focus:outline-none group\" data-kid=\"44\">\n                        <span class=\"text-lg\" data-kid=\"45\">What do you look for in a founder?</span>\n                        <i data-lucide=\"chevron-down\" class=\"lucide-icon w-5 h-5 text-gray-500 group-hover:text-white transition-transform duration-300\" data-kid=\"46\"></i>\n                    </button>\n                    <div class=\"faq-answer max-h-0 overflow-hidden transition-all duration-300 ease-in-out\" data-kid=\"47\">\n                        <div class=\"px-6 pb-6 text-gray-400 leading-relaxed\" data-kid=\"48\">\n                            Resilience, domain expertise, coachability, and a clear vision for the problem being solved. We back people who are obsessed with building the future.\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n        </div>\n\n        \n        <div id=\"bottom-gradient\" class=\"absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-[#120F17] to-transparent z-20 pointer-events-none transition-opacity duration-300\" data-kid=\"49\"></div>\n    </div>\n\n    \n    <div class=\"mt-10 flex flex-col items-center gap-3 animate-pulse\" data-kid=\"50\">\n        <span class=\"text-gray-500 text-[10px] uppercase tracking-[0.2em] font-bold\" data-kid=\"51\">Scroll to discover</span>\n        <div class=\"w-px h-8 bg-gradient-to-b from-gray-700 to-transparent\" data-kid=\"52\"></div>\n    </div>\n</div>\n\n<style data-kid=\"53\">\n    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap');\n\n    .font-sans {\n        font-family: 'Plus Jakarta Sans', sans-serif;\n    }\n\n    /* Animation Classes */\n    .item-in-view {\n        opacity: 1 !important;\n        transform: scale(1) translateY(0) !important;\n    }\n\n    /* FAQ Expanded State */\n    .faq-item.active .faq-answer {\n        max-height: 200px; /* Large enough to fit any answer */\n    }\n    \n    .faq-item.active .lucide-icon {\n        transform: rotate(180deg);\n        color: #fff;\n    }\n\n    .faq-item.active > div {\n        background-color: #1a1a1a;\n        border-color: rgba(255, 255, 255, 0.1);\n        box-shadow: 0 0 20px rgba(255, 255, 255, 0.02);\n    }\n\n    .faq-item:hover:not(.active) > div {\n        background-color: #161616;\n        border-color: rgba(255, 255, 255, 0.08);\n    }\n</style>\n\n<script src=\"https://unpkg.com/lucide@latest\" data-kid=\"54\"></script>\n<script data-kid=\"55\">\n    document.addEventListener('DOMContentLoaded', () => {\n        // Initialize Icons\n        lucide.createIcons();\n\n        const listContainer = document.getElementById('list-container');\n        const topGradient = document.getElementById('top-gradient');\n        const bottomGradient = document.getElementById('bottom-gradient');\n        const faqItems = document.querySelectorAll('.faq-item');\n\n        // 1. Entrance Animations using Intersection Observer\n        const observerOptions = {\n            threshold: 0.2,\n            root: listContainer\n        };\n\n        const observer = new IntersectionObserver((entries) => {\n            entries.forEach((entry, index) => {\n                if (entry.isIntersecting) {\n                    // Add a small staggered delay for a smoother effect if visible at once\n                    setTimeout(() => {\n                        entry.target.classList.add('item-in-view');\n                    }, 50 * entry.target.dataset.index);\n                }\n            });\n        }, observerOptions);\n\n        faqItems.forEach(item => observer.observe(item));\n\n        // 2. Scroll Gradient Logic\n        const handleScroll = () => {\n            const { scrollTop, scrollHeight, clientHeight } = listContainer;\n            \n            // Top gradient opacity\n            const topOpacity = Math.min(scrollTop / 50, 1);\n            topGradient.style.opacity = topOpacity;\n\n            // Bottom gradient opacity\n            const bottomDistance = scrollHeight - (scrollTop + clientHeight);\n            const bottomOpacity = Math.min(bottomDistance / 50, 1);\n            bottomGradient.style.opacity = bottomOpacity;\n        };\n\n        listContainer.addEventListener('scroll', handleScroll);\n        // Trigger initial check\n        handleScroll();\n\n        // 3. FAQ Toggle Logic\n        const triggers = document.querySelectorAll('.faq-trigger');\n        \n        triggers.forEach(trigger => {\n            trigger.addEventListener('click', () => {\n                const item = trigger.closest('.faq-item');\n                const isActive = item.classList.contains('active');\n\n                // Close all other items\n                faqItems.forEach(otherItem => {\n                    if (otherItem !== item) {\n                        otherItem.classList.remove('active');\n                    }\n                });\n\n                // Toggle current item\n                item.classList.toggle('active');\n            });\n        });\n\n        // 4. Hover Keyboard navigation feel (Selection)\n        faqItems.forEach(item => {\n            item.addEventListener('mouseenter', () => {\n                // Optional: set a 'selected' class if we wanted to mirror the AnimatedList focus logic exactly\n                // item.classList.add('selected');\n            });\n        });\n    });\n</script>\n",
