      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap');\n\n  :root {\n    --brand-purple: #2D2754;\n    --brand-purple-light: #4c3ba5;\n    --brand-cyan: #32E1FC;\n    --brand-cyan-light: rgba(50, 225, 252, 0.08);\n    --brand-cyan-glow: rgba(50, 225, 252, 0.15);\n  }\n\n  .font-jakarta {\n    font-family: 'Plus Jakarta Sans', sans-serif;\n  }\n\n  /* Custom Scrollbar for the Animated List */\n  .faq-scroll-container::-webkit-scrollbar {\n    width: 4px;\n  }\n\n  .faq-scroll-container::-webkit-scrollbar-track {\n    background: transparent;\n  }\n\n  .faq-scroll-container::-webkit-scrollbar-thumb {\n    background: #E2E8F0;\n    border-radius: 10px;\n    transition: background 0.3s;\n  }\n\n  .faq-scroll-container:hover::-webkit-scrollbar-thumb {\n    background: var(--brand-cyan);\n  }\n\n  /* Entrance Animation: Initial state */\n  .faq-item {\n    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.6s ease;\n    transform: translateY(20px) scale(0.96);\n    opacity: 0;\n  }\n\n  /* Entrance Animation: Triggered state */\n  .faq-item.in-view {\n    transform: translateY(0) scale(1);\n    opacity: 1;\n  }\n\n  /* Selection state (keyboard/hover) */\n  .faq-item.selected {\n    border-color: var(--brand-cyan);\n    box-shadow: 0 4px 20px -2px rgba(50, 225, 252, 0.15);\n  }\n\n  .faq-item.selected h3 {\n    color: #4c3ba5 !important;\n  }\n\n  /* Accordion Content transition */\n  .accordion-content {\n    max-height: 0;\n    overflow: hidden;\n    transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease, padding 0.4s ease;\n    opacity: 0;\n  }\n\n  .accordion-open .accordion-content {\n    max-height: 500px; /* Allow for enough space */\n    padding-bottom: 1.5rem;\n    opacity: 1;\n  }\n\n  .accordion-open .chevron-icon {\n    transform: rotate(180deg);\n    color: var(--brand-cyan);\n  }\n\n  .accordion-open {\n    background: white;\n    border-color: var(--brand-cyan) !important;\n    box-shadow: 0 10px 30px -10px rgba(45, 39, 84, 0.1);\n  }\n\n  /* Subtle background pattern */\n  .bg-grid {\n    background-image: radial-gradient(circle at 2px 2px, #E2E8F0 1px, transparent 0);\n    background-size: 40px 40px;\n  }\n</style>\n\n<div class=\"font-jakarta bg-slate-50 min-h-[950px] flex flex-col items-center py-20 px-6 relative overflow-hidden bg-grid\" data-kid=\"1\">\n  \n  <div class=\"absolute -top-24 -left-24 w-96 h-96 bg-purple-200/30 rounded-full blur-3xl pointer-events-none\" data-kid=\"2\"></div>\n  <div class=\"absolute top-1/2 -right-24 w-80 h-80 bg-cyan-100/40 rounded-full blur-3xl pointer-events-none\" data-kid=\"3\"></div>\n\n  <section class=\"w-full max-w-3xl relative z-10\" data-kid=\"4\">\n    \n    <div class=\"text-center mb-12\" data-kid=\"5\">\n      <div class=\"inline-flex items-center gap-2 px-3 py-1 mb-6 text-[10px] font-bold tracking-[0.2em] text-cyan-600 uppercase bg-white border border-cyan-100 rounded-lg shadow-sm\" data-kid=\"6\">\n        <span class=\"w-1.5 h-1.5 rounded-full bg-cyan-400 animate-pulse\" data-kid=\"7\"></span>\n        Knowledge Center\n      </div>\n      <h2 class=\"text-4xl md:text-5xl font-extrabold mb-5 tracking-tight leading-tight\" style=\"color: var(--brand-purple);\" data-kid=\"8\">\n        Questions you might have\n      </h2>\n      <p class=\"text-slate-500 text-lg max-w-lg mx-auto font-medium opacity-80\" data-kid=\"9\">\n        Everything you need to know about our funding process and growth strategy.\n      </p>\n    </div>\n\n    \n    <div class=\"relative group mt-8\" data-kid=\"10\">\n      \n      <div id=\"top-gradient\" class=\"absolute top-0 left-0 right-0 h-32 bg-gradient-to-b from-slate-50 to-transparent z-20 pointer-events-none opacity-0 transition-opacity duration-500\" data-kid=\"11\"></div>\n\n      \n      <div id=\"faq-list\" class=\"faq-scroll-container max-h-[580px] overflow-y-auto px-1 py-4 space-y-4 relative scroll-smooth\" data-kid=\"12\">\n        \n        \n        <div class=\"faq-item group/item border border-slate-200 bg-white/70 backdrop-blur-sm rounded-2xl overflow-hidden cursor-pointer hover:border-cyan-200 transition-all duration-300\" data-index=\"0\" data-kid=\"13\">\n          <div class=\"flex items-center justify-between px-7 py-6 text-left\" data-kid=\"14\">\n            <h3 class=\"text-lg font-bold pr-8 transition-colors duration-300\" style=\"color: var(--brand-purple);\" data-kid=\"15\">What stages do you invest in?</h3>\n            <div class=\"chevron-icon transition-transform duration-500 flex-shrink-0 text-slate-400\" data-kid=\"16\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"17\"><path d=\"m6 9 6 6 6-6\" data-kid=\"18\"></path></svg>\n            </div>\n          </div>\n          <div class=\"accordion-content px-7\" data-kid=\"19\">\n            <p class=\"text-slate-500 leading-relaxed font-medium\" data-kid=\"20\">\n              We invest from Pre-Seed through Series B and beyond, depending on the opportunity. Our sweet spot is typically early-stage startups showing initial traction with a scalable product-market fit.\n            </p>\n          </div>\n        </div>\n\n        \n        <div class=\"faq-item group/item border border-slate-200 bg-white/70 backdrop-blur-sm rounded-2xl overflow-hidden cursor-pointer hover:border-cyan-200 transition-all duration-300\" data-index=\"1\" data-kid=\"21\">\n          <div class=\"flex items-center justify-between px-7 py-6 text-left\" data-kid=\"22\">\n            <h3 class=\"text-lg font-bold pr-8 transition-colors duration-300\" style=\"color: var(--brand-purple);\" data-kid=\"23\">Do you invest outside India?</h3>\n            <div class=\"chevron-icon transition-transform duration-500 flex-shrink-0 text-slate-400\" data-kid=\"24\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"25\"><path d=\"m6 9 6 6 6-6\" data-kid=\"26\"></path></svg>\n            </div>\n          </div>\n          <div class=\"accordion-content px-7\" data-kid=\"27\">\n            <p class=\"text-slate-500 leading-relaxed font-medium\" data-kid=\"28\">\n              Yes, we invest globally with a focus on emerging markets and high-growth regions. Our network spans across Southeast Asia, MENA, and North America, helping local heroes go global.\n            </p>\n          </div>\n        </div>\n\n        \n        <div class=\"faq-item group/item border border-slate-200 bg-white/70 backdrop-blur-sm rounded-2xl overflow-hidden cursor-pointer hover:border-cyan-200 transition-all duration-300\" data-index=\"2\" data-kid=\"29\">\n          <div class=\"flex items-center justify-between px-7 py-6 text-left\" data-kid=\"30\">\n            <h3 class=\"text-lg font-bold pr-8 transition-colors duration-300\" style=\"color: var(--brand-purple);\" data-kid=\"31\">How long does the process take?</h3>\n            <div class=\"chevron-icon transition-transform duration-500 flex-shrink-0 text-slate-400\" data-kid=\"32\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"33\"><path d=\"m6 9 6 6 6-6\" data-kid=\"34\"></path></svg>\n            </div>\n          </div>\n          <div class=\"accordion-content px-7\" data-kid=\"35\">\n            <p class=\"text-slate-500 leading-relaxed font-medium\" data-kid=\"36\">\n              From application to term sheet typically takes 3–6 weeks depending on due diligence complexity. We aim to move at the speed of founders while ensuring deep alignment on vision and strategy.\n            </p>\n          </div>\n        </div>\n\n        \n        <div class=\"faq-item group/item border border-slate-200 bg-white/70 backdrop-blur-sm rounded-2xl overflow-hidden cursor-pointer hover:border-cyan-200 transition-all duration-300\" data-index=\"3\" data-kid=\"37\">\n          <div class=\"flex items-center justify-between px-7 py-6 text-left\" data-kid=\"38\">\n            <h3 class=\"text-lg font-bold pr-8 transition-colors duration-300\" style=\"color: var(--brand-purple);\" data-kid=\"39\">What equity stake do you take?</h3>\n            <div class=\"chevron-icon transition-transform duration-500 flex-shrink-0 text-slate-400\" data-kid=\"40\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"41\"><path d=\"m6 9 6 6 6-6\" data-kid=\"42\"></path></svg>\n            </div>\n          </div>\n          <div class=\"accordion-content px-7\" data-kid=\"43\">\n            <p class=\"text-slate-500 leading-relaxed font-medium\" data-kid=\"44\">\n              We typically take 5–15% equity, negotiated based on stage and valuation. Our philosophy is to be long-term partners, ensuring founders retain enough skin in the game for massive scale.\n            </p>\n          </div>\n        </div>\n\n        \n        <div class=\"faq-item group/item border border-slate-200 bg-white/70 backdrop-blur-sm rounded-2xl overflow-hidden cursor-pointer hover:border-cyan-200 transition-all duration-300\" data-index=\"4\" data-kid=\"45\">\n          <div class=\"flex items-center justify-between px-7 py-6 text-left\" data-kid=\"46\">\n            <h3 class=\"text-lg font-bold pr-8 transition-colors duration-300\" style=\"color: var(--brand-purple);\" data-kid=\"47\">Do you lead rounds?</h3>\n            <div class=\"chevron-icon transition-transform duration-500 flex-shrink-0 text-slate-400\" data-kid=\"48\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"49\"><path d=\"m6 9 6 6 6-6\" data-kid=\"50\"></path></svg>\n            </div>\n          </div>\n          <div class=\"accordion-content px-7\" data-kid=\"51\">\n            <p class=\"text-slate-500 leading-relaxed font-medium\" data-kid=\"52\">\n              We can lead or co-invest depending on the deal structure. When we lead, we provide active board support and strategic introductions to our global LP network.\n            </p>\n          </div>\n        </div>\n\n        \n        <div class=\"faq-item group/item border border-slate-200 bg-white/70 backdrop-blur-sm rounded-2xl overflow-hidden cursor-pointer hover:border-cyan-200 transition-all duration-300\" data-index=\"5\" data-kid=\"53\">\n          <div class=\"flex items-center justify-between px-7 py-6 text-left\" data-kid=\"54\">\n            <h3 class=\"text-lg font-bold pr-8 transition-colors duration-300\" style=\"color: var(--brand-purple);\" data-kid=\"55\">What do you look for in a founder?</h3>\n            <div class=\"chevron-icon transition-transform duration-500 flex-shrink-0 text-slate-400\" data-kid=\"56\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"57\"><path d=\"m6 9 6 6 6-6\" data-kid=\"58\"></path></svg>\n            </div>\n          </div>\n          <div class=\"accordion-content px-7\" data-kid=\"59\">\n            <p class=\"text-slate-500 leading-relaxed font-medium\" data-kid=\"60\">\n              We prioritize resilience, domain expertise, and coachability. We back founders who possess an \"unfair advantage\" in their market and a clear vision for an inevitable future.\n            </p>\n          </div>\n        </div>\n\n      </div>\n\n      \n      <div id=\"bottom-gradient\" class=\"absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-slate-50 to-transparent z-20 pointer-events-none transition-opacity duration-500\" data-kid=\"61\"></div>\n    </div>\n\n    \n    <div class=\"mt-16 text-center\" data-kid=\"62\">\n      <div class=\"p-10 rounded-[2.5rem] bg-white border border-slate-100 shadow-xl shadow-slate-200/50 relative overflow-hidden group\" data-kid=\"63\">\n        \n        <div class=\"absolute -right-10 -top-10 w-40 h-40 bg-cyan-400/5 rounded-full blur-2xl group-hover:bg-cyan-400/10 transition-colors duration-700\" data-kid=\"64\"></div>\n        \n        <h4 class=\"text-xl font-bold mb-3\" style=\"color: var(--brand-purple);\" data-kid=\"65\">Can't find what you're looking for?</h4>\n        <p class=\"text-slate-400 font-medium mb-8\" data-kid=\"66\">Our team is ready to assist with more specific inquiries.</p>\n        \n        <button class=\"group relative px-10 py-4 rounded-2xl text-white font-bold transition-all hover:scale-105 active:scale-95 overflow-hidden shadow-lg shadow-purple-200\" style=\"background: var(--brand-purple);\" data-kid=\"67\">\n          <div class=\"absolute inset-0 bg-gradient-to-r from-transparent via-white/10 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000\" data-kid=\"68\"></div>\n          <span class=\"relative z-10 flex items-center justify-center gap-2\" data-kid=\"69\">\n            Ask us anything\n            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"70\"><path d=\"M5 12h14m-7-7 7 7-7 7\" data-kid=\"71\"></path></svg>\n          </span>\n        </button>\n      </div>\n      \n      <p class=\"mt-8 text-slate-400 text-sm font-semibold tracking-wide flex items-center justify-center gap-2\" data-kid=\"72\">\n        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"text-cyan-500\" data-kid=\"73\"><path d=\"M22 11.08V12a10 10 0 1 1-5.93-9.14\" data-kid=\"74\"></path><polyline points=\"22 4 12 14.01 9 11.01\" data-kid=\"75\"></polyline></svg>\n        Average response time: &lt; 24 hours\n      </p>\n    </div>\n  </section>\n</div>\n\n<script data-kid=\"76\">\n  document.addEventListener('DOMContentLoaded', () => {\n    const list = document.getElementById('faq-list');\n    const items = document.querySelectorAll('.faq-item');\n    const topGradient = document.getElementById('top-gradient');\n    const bottomGradient = document.getElementById('bottom-gradient');\n    \n    let selectedIndex = -1;\n\n    // 1. Entrance Animation logic (Intersection Observer)\n    const observerOptions = {\n      root: null,\n      threshold: 0.2,\n      rootMargin: '0px'\n    };\n\n    const observer = new IntersectionObserver((entries) => {\n      entries.forEach((entry) => {\n        if (entry.isIntersecting) {\n          const index = entry.target.dataset.index;\n          setTimeout(() => {\n            entry.target.classList.add('in-view');\n          }, index * 100); // Stagger effect\n        }\n      });\n    }, observerOptions);\n\n    items.forEach(item => observer.observe(item));\n\n    // 2. Scroll Gradient Logic (AnimatedList behavior)\n    const updateGradients = () => {\n      const scrollTop = list.scrollTop;\n      const scrollHeight = list.scrollHeight;\n      const clientHeight = list.clientHeight;\n\n      // Calculate opacity based on scroll position\n      topGradient.style.opacity = Math.min(scrollTop / 60, 1);\n      \n      const bottomDistance = scrollHeight - (scrollTop + clientHeight);\n      bottomGradient.style.opacity = scrollHeight <= clientHeight ? 0 : Math.min(bottomDistance / 60, 1);\n    };\n\n    list.addEventListener('scroll', updateGradients);\n    window.addEventListener('resize', updateGradients);\n    updateGradients(); // Run on load\n\n    // 3. Click / Accordion / Selection Logic\n    const toggleItem = (index) => {\n      const item = items[index];\n      const isOpen = item.classList.contains('accordion-open');\n      \n      // Close all others\n      items.forEach(i => i.classList.remove('accordion-open'));\n      \n      if (!isOpen) {\n        item.classList.add('accordion-open');\n        // Smoother scroll to ensure fully in view\n        setTimeout(() => {\n            item.scrollIntoView({ behavior: 'smooth', block: 'nearest' });\n        }, 100);\n      }\n    };\n\n    const setSelection = (index) => {\n      selectedIndex = index;\n      items.forEach((item, idx) => {\n        if (idx === index) {\n          item.classList.add('selected');\n        } else {\n          item.classList.remove('selected');\n        }\n      });\n    };\n\n    items.forEach((item, index) => {\n      item.addEventListener('click', () => {\n        toggleItem(index);\n        setSelection(index);\n      });\n\n      item.addEventListener('mouseenter', () => {\n        setSelection(index);\n      });\n    });\n\n    // 4. Keyboard Navigation (AnimatedList feature)\n    document.addEventListener('keydown', (e) => {\n      if (['ArrowDown', 'ArrowUp', 'Enter'].includes(e.key)) {\n        if (selectedIndex === -1) {\n            setSelection(0);\n            return;\n        }\n\n        if (e.key === 'ArrowDown') {\n          e.preventDefault();\n          const next = Math.min(selectedIndex + 1, items.length - 1);\n          setSelection(next);\n          scrollSelectionIntoView(next);\n        } else if (e.key === 'ArrowUp') {\n          e.preventDefault();\n          const prev = Math.max(selectedIndex - 1, 0);\n          setSelection(prev);\n          scrollSelectionIntoView(prev);\n        } else if (e.key === 'Enter') {\n          e.preventDefault();\n          toggleItem(selectedIndex);\n        }\n      }\n    });\n\n    const scrollSelectionIntoView = (index) => {\n      const item = items[index];\n      const containerRect = list.getBoundingClientRect();\n      const itemRect = item.getBoundingClientRect();\n      \n      const buffer = 80; // Margin for gradients\n\n      if (itemRect.top < containerRect.top + buffer) {\n        list.scrollBy({ top: itemRect.top - containerRect.top - buffer, behavior: 'smooth' });\n      } else if (itemRect.bottom > containerRect.bottom - buffer) {\n        list.scrollBy({ top: itemRect.bottom - containerRect.bottom + buffer, behavior: 'smooth' });\n      }\n    };\n  });\n</script>\n",
